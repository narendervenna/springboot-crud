{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",



  "timezone": "GMT",


    "schedule": [
      "* 20 * * 5",
      "* 20 * * 6"

  ],

  "prConcurrentLimit": 4,
  "prHourlyLimit": 30,
  "branchConcurrentLimit": 3,

  "dependencyDashboard": true,

  "packageRules": [
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "minor-updates-batch",
      "groupSlug": "minor-batch"
    },
    {
      "matchUpdateTypes": ["major"]
    },
    {
      "matchPackagePatterns": ["binding","h2"],
      "enabled": false
    },
    {
      "matchPackagePatterns": [""],
      "enabled": false
    }
  ]
}