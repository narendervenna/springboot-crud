{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "UTC",
  "schedule": [
      "* 2-7 * * 1",
      "* 2-7 * * 2"

  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 4,
  "prHourlyLimit": 50,
  "packageRules": [
    {
      "matchPackagePatterns": ["h2"],
      "enabled": false
    }
  ]
}